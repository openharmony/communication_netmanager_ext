import("//build/config/features.gni")
import("//build/test.gni")
import("//foundation/communication/netmanager_ext/netmanager_ext_config.gni")

EXT_SECURITY_PATH = "../../.."

ohos_fuzztest("NetFirewallClientFuzzTest") {
  module_out_path = fuzz_test_path
  fuzz_config_file = "$NETMANAGER_EXT_ROOT/test/netfirewallmanager/fuzztest/netfirewallclient_fuzzer"

  include_dirs = [
    "$EXT_INNERKITS_ROOT/include",
    "$EXT_SECURITY_PATH/security",
    "$NETMANAGER_EXT_ROOT/utils/log/include",
    "$NETFIREWALLMANAGER_SOURCE_DIR/include",
    "$EXT_INNERKITS_ROOT/netfirewallclient/include",
    "$NETMANAGER_EXT_ROOT/test/netmanager_ext_mock_test",
    "$NETMANAGER_EXT_ROOT/frameworks/js/napi/netfirewall/include",
    "$NETMANAGER_EXT_ROOT/frameworks/js/napi/netfirewall/include/context",
  ]

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
    "-flto",
    "-fvisibility=hidden",
  ]

  ldflags = [
    "-flto",
  ]

  sources = [
    "$NETMANAGER_EXT_ROOT/frameworks/js/napi/netfirewall/src/context/net_firewall_param_check.cpp",
    "$NETMANAGER_EXT_ROOT/frameworks/js/napi/netfirewall/src/context/net_firewall_rule_parse.cpp",
    "netfirewall_client_fuzzer.cpp"
  ]

  deps = [
    "$EXT_INNERKITS_ROOT/netfirewallclient:netfirewall_manager_if",
    "$EXT_INNERKITS_ROOT/netfirewallclient:netfirewall_parcel",
    "$NETFIREWALLMANAGER_SOURCE_DIR:netfirewall_manager_static",
    "$NETMANAGER_EXT_ROOT/utils:net_event_report",
    "$NETMANAGER_EXT_ROOT/frameworks/js/napi/netfirewall:netfirewall",
  ]

  external_deps = [
    "ability_runtime:app_manager",
    "access_token:libaccesstoken_sdk",
    "access_token:libnativetoken_shared",
    "access_token:libtoken_setproc",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "dhcp:dhcp_sdk",
    "eventhandler:libeventhandler",
    "ffrt:libffrt",
    "hilog:libhilog",
    "hisysevent:libhisysevent",
    "ipc:ipc_core",
    "json:nlohmann_json_static",
    "napi:ace_napi",
    "netmanager_base:napi_utils",
    "netmanager_base:netsys_controller",
    "netmanager_base:net_conn_manager_if",
    "netmanager_base:net_manager_common",
    "netmanager_base:net_native_manager_if",
    "netmanager_base:net_service_common",
    "os_account:os_account_innerkits",
    "preferences:native_preferences",
  ]

  defines = [
    "HI_LOG_ENABLE",
    "NETMGR_LOG_TAG = \"NetFirewallClientFuzzTest\"",
    "LOG_DOMAIN = 0xD0015B0",
    "private = public",
    "protected = public",
  ]

  if (enable_netmgr_ext_debug) {
    defines += [ "NETMGR_DEBUG" ]
  }

  part_name = "netmanager_ext"
  subsystem_name = "communication"
}

###############################################################################
group("fuzztest") {
  testonly = true
  deps = [ ":NetFirewallClientFuzzTest" ]
}
###############################################################################
