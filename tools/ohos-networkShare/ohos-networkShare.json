          },
          "format": {
            "type": "string",
            "enum": ["json"],
            "description": "Output format, json for structured output"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "failed"]
          },
          "data": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string",
                "description": "CLI tool name"
              },
              "commands": {
                "type": "array",
                "description": "List of available commands",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Command name"
                    },
                    "description": {
                      "type": "string",
                      "description": "Command description"
                    }
                  }
                }
              }
            }
          },
          "errCode": {
            "type": "string",
            "description": "Error code when operation failed"
          },
          "errMsg": {
            "type": "string",
